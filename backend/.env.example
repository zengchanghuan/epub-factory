# OpenAI Configuration
OPENAI_API_KEY=sk-your_actual_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# For DeepSeek, you would use:
# OPENAI_API_KEY=sk-your_deepseek_key
# OPENAI_MODEL=deepseek-chat
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# 翻译质量：temperature 建议 1.3（DeepSeek 文档推荐），见 https://api-docs.deepseek.com/zh-cn/quick_start/parameter_settings
# OPENAI_TEMPERATURE=1.3

# Translation resilience (optional): fallback URLs/models, timeout, retries, concurrency
# OPENAI_BASE_URL_FALLBACKS=https://backup.example.com/v1
# OPENAI_MODEL_FALLBACKS=gpt-4o,deepseek-reasoner
# OPENAI_REQUEST_TIMEOUT=25
# OPENAI_MAX_RETRIES=2
# OPENAI_CONCURRENCY=5

# 持久化任务列表（任务中心、重启后任务不丢失）
# 不设置则使用内存存储，重启后任务列表清空
# DATABASE_URL=sqlite:///./epub_jobs.db
# DATABASE_URL=postgresql://user:password@host:5432/epub_factory

# Background Task Infrastructure
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# Notifications (optional)
# NOTIFY_EMAIL_ENABLED=0
# NOTIFY_EMAIL_TO=user@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# 后台 Token/费用汇总接口（GET /api/v2/admin/translation-stats）可选鉴权
# ADMIN_SECRET=your_secret_string

# CORS: 生产环境建议仅放你的正式域名（逗号分隔）
# CORS_ALLOW_ORIGINS=https://fixepub.com,https://www.fixepub.com

# 反向代理白名单（CIDR，逗号分隔）：
# 只有 TCP 对端落在这些网段时，才会信任 X-Real-IP / X-Forwarded-For 头。
# 部署在 Nginx 后端时保持默认（127.0.0.1/32）即可；如果有多级代理需要把外层 LB 的内网段也加进来。
# TRUSTED_PROXIES=127.0.0.1/32,::1/128

# ─── 资源上限（按部署机器规格调）─────────────────────────────────────
# 单文件大小上限（MB）。默认 20，按机器内存与公网带宽分级：
#   2C2G / 3Mbps（小机）：建议 60（覆盖 95% 带插图 EPUB；用户下载 ~2分40秒）
#   2C4G / 5Mbps（推荐）：建议 80（覆盖 99% EPUB；下载 ~2分10秒）
#   4C8G / 8Mbps+      ：建议 150（含画册/扫描）
# MAX_FILE_SIZE_MB=60

# Celery worker 并发数（必须显式，默认会跑满 CPU 核数 → 易 OOM）。
# 2GiB 内存机器强烈建议保持 1；升 4GiB 后可调到 2。
# CELERY_WORKER_CONCURRENCY=1
# CELERY_TASK_TIME_LIMIT=1800        # 单任务硬超时（秒），默认 30 分钟
# CELERY_TASK_SOFT_TIME_LIMIT=1500   # 软超时（秒），任务侧可优雅退出

# 支付回调校验：建议配置商户 PID（seller_id）做二次验签
# ALIPAY_SELLER_ID=2088xxxxxxxxxxxx

# 翻译任务的应付金额（元，字符串形式以保持小数精度），下单与回调都用同一个值。
# TRANSLATION_PRICE_CNY=0.01

# 旧任务（无 access_token）的 session/IP 兜底鉴权时间窗（天，超过则直接拒绝）。
# LEGACY_ACCESS_WINDOW_DAYS=30

# 任务 access_token 默认有效期（天）；过期后需要重新发起任务获取新 token。
# ACCESS_TOKEN_TTL_DAYS=7

# 下载链接签名密钥（HMAC-SHA256）；未配置则禁用签名 URL，下载只接受 token 鉴权。
# 建议生成一段足够随机的字符串，如 `openssl rand -hex 32`。
# DOWNLOAD_SIGN_SECRET=replace_with_a_long_random_string
# DOWNLOAD_SIGN_TTL_SECONDS=600

# 大模型余额监控（每天 08:00 查询，低于阈值写 ERROR → CLS 告警）
# BALANCE_WARN_CNY=10            余额低于多少元触发告警（默认 10）
# BALANCE_CHECK_PROVIDER=deepseek  提供商标识，仅用于日志
# BALANCE_CHECK_HOUR=8           每天几点检查（默认 08:00）
# BALANCE_CHECK_MINUTE=0

# 支付对账 cron 配置（Celery Beat 驱动）
# RECONCILE_STALE_MINUTES=30      订单滞留多少分钟后才纳入对账（默认 30）
# RECONCILE_TIMEOUT_HOURS=2       超过多少小时仍未付款则自动关单（默认 2）
# RECONCILE_CRON_HOUR=2           每天几点执行（默认凌晨 2 点，Asia/Shanghai）
# RECONCILE_CRON_MINUTE=0

# 结构化日志文件路径（供 LogListener/CLS 采集）；不设置则只输出到 stdout
# 注意：路径需放在子目录下，LogListener 通配符 /**/app.log 才能匹配
# LOG_FILE=/var/log/epub-factory/api/app.log

# 错误上报：设置后 job 失败/HTTP 5xx 会自动上报到 Sentry
# 在 Sentry 项目 Settings → Client Keys 复制 DSN
# SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/project-id
#
# 运行环境标签（显示在 Sentry Issues 的 environment 过滤器）
# APP_ENV=production
#
# 性能追踪采样率（0.0-1.0）；生产建议 0.05~0.1 节省配额
# SENTRY_TRACES_RATE=0.1

# ─── 用户认证 (User Auth) ────────────────────────────────────────────────────
# JWT 签名密钥：生产环境必须替换为足够随机的字符串（openssl rand -hex 32）
# JWT_SECRET=replace_with_a_long_random_secret_key
# JWT_EXPIRE_DAYS=7

# 阿里云短信服务（发送手机验证码）
# 在阿里云 RAM 控制台创建子账号，授权 AliyunDysmsFullAccess
# ALIYUN_ACCESS_KEY_ID=your_access_key_id
# ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
# SMS_SIGN_NAME=你的短信签名
# SMS_TEMPLATE_CODE=SMS_XXXXXXXXX

# Google OAuth 2.0（在 Google Cloud Console → APIs & Services → Credentials 创建）
# GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_client_secret
# GOOGLE_REDIRECT_URI=https://fixepub.com/api/v2/auth/google/callback

# 微信公众号网页授权（需已认证服务号，在公众平台 → 设置与开发 → 接口权限开启网页授权）
# WECHAT_APP_ID=wx_your_app_id
# WECHAT_APP_SECRET=your_app_secret
# WECHAT_REDIRECT_URI=https://fixepub.com/api/v2/auth/wechat/callback