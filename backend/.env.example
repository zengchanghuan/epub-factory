# OpenAI Configuration
OPENAI_API_KEY=sk-your_actual_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# For DeepSeek, you would use:
# OPENAI_API_KEY=sk-your_deepseek_key
# OPENAI_MODEL=deepseek-chat
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# 翻译质量：temperature 建议 1.3（DeepSeek 文档推荐），见 https://api-docs.deepseek.com/zh-cn/quick_start/parameter_settings
# OPENAI_TEMPERATURE=1.3

# Translation resilience (optional): fallback URLs/models, timeout, retries, concurrency
# OPENAI_BASE_URL_FALLBACKS=https://backup.example.com/v1
# OPENAI_MODEL_FALLBACKS=gpt-4o,deepseek-reasoner
# OPENAI_REQUEST_TIMEOUT=25
# OPENAI_MAX_RETRIES=2
# OPENAI_CONCURRENCY=5

# 持久化任务列表（任务中心、重启后任务不丢失）
# 不设置则使用内存存储，重启后任务列表清空
# DATABASE_URL=sqlite:///./epub_jobs.db
# DATABASE_URL=postgresql://user:password@host:5432/epub_factory

# Background Task Infrastructure
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# Notifications (optional)
# NOTIFY_EMAIL_ENABLED=0
# NOTIFY_EMAIL_TO=user@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# 后台 Token/费用汇总接口（GET /api/v2/admin/translation-stats）可选鉴权
# ADMIN_SECRET=your_secret_string

# 错误上报：设置后 job 失败会自动上报到 Sentry（在 Sentry 项目 Settings → Client Keys 复制 DSN）
# SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/project-id